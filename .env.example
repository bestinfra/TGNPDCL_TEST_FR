# Copy to .env.local or .env.development.local and adjust as needed.
# Vite exposes only variables prefixed with VITE_

# Backend API root (include /api suffix)
VITE_API_BASE_URL=http://localhost:4249/api

# Optional: request timeout in ms (default 20000)
# VITE_API_TIMEOUT=20000

# Optional: WebSocket
# VITE_SOCKET_URL=ws://localhost:4249/api
# VITE_SOCKET_ENABLED=true

# Federated SuperAdmin remote
# VITE_SUPER_ADMIN_URL=https://admin.bestinfra.app/assets/remoteEntry.js
